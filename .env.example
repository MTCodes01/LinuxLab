# LinuxLab Configuration
# Copy this to .env and customize

# ─── Security ──────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Admin Credentials ─────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── Database ──────────────────────────────────────────
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///./data/linuxlab.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/linuxlab

# ─── Docker ────────────────────────────────────────────
DOCKER_SOCKET_PATH=/var/run/docker.sock
CONTAINER_NETWORK=linuxlab-containers
CONTAINER_PREFIX=linuxlab-

# ─── Server ────────────────────────────────────────────
NGINX_PORT=80
CORS_ORIGINS=http://localhost:5173,http://localhost:80
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ─── Features ──────────────────────────────────────────
DEFAULT_CONTAINER_LIFETIME_HOURS=0
MAX_CONTAINERS=50
ENABLE_SSH=true
SSH_PORT_RANGE_START=2200
SSH_PORT_RANGE_END=2299
